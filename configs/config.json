{
  "address": "0.0.0.0",
  "port": 2232,
  "assets": "",
  "database": {
    "type": "sqlite3",
    "db_file": "/opt/openbox/data/openbox.db"
  },
  "temp_dir": "/opt/openbox/tmp",
  "cache": {
    "expiration": 60,
    "cleanup_interval": 120
  },
  "log": {
    "enable": true,
    "name": "/opt/openbox/logs/openbox.log"
  },
  "mcp": {
    "enable": true,
    "port": 5245
  },
  "site_title": "OpenBox",
  "announcement": "Welcome to OpenBox - Single Port 2232",
  "name": "OpenBox",
  "brand": "OpenBox",
  "version": "2.0.0",
  "security": {
    "yubikey": true,
    "2fa": true,
    "session_timeout": 900,
    "max_login_attempts": 3,
    "lockout_duration": 900,
    "passkey_enabled": true,
    "single_connection": true,
    "single_port": true,
    "rate_limit": "1 per 10s"
  }
}
