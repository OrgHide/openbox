# OpenBox Northflank SSH Configuration
Host northflank-openbox
    HostName northflank.com
    User deploy
    Port 8022
    IdentityFile ~/openbox/deploy/northflank-deploy-key
    StrictHostKeyChecking yes
    ServerAliveInterval 60
    ServerAliveCountMax 3
    LocalForward 5244 localhost:5244
    LocalForward 8080 localhost:8080
    
# OpenBox Production
Host openbox-prod
    HostName openbox.northflank.com
    User admin
    Port 8022
    IdentityFile ~/openbox/deploy/northflank-deploy-key
    StrictHostKeyChecking yes
