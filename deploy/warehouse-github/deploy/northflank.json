{
  "name": "warehouse-storage",
  "type": "service",
  "region": "us-east-1",
  "scale": {
    "replicas": 1,
    "memory": "1024Mi",
    "cpu": "500m"
  },
  "environment": {
    "RCLONE_CONFIG": "/etc/rclone/rclone.conf",
    "ALIST_PORT": "5244",
    "WEBDAV_PORT": "8080",
    "SSH_PORT": "8022",
    "SECURITY_LEVEL": "maximum"
  },
  "healthchecks": {
    "webui": "/api/public/settings",
    "webdav": "/",
    "interval": 30,
    "timeout": 5
  },
  "logging": {
    "level": "info",
    "retention": "30d",
    "audit": true
  },
  "security": {
    "yubikey": true,
    "2fa": true,
    "ssh_keys": true,
    "single_connection": true
  }
}
